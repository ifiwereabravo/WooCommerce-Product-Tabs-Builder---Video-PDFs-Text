/** * MODULE 2: FRONTEND RENDERING (VIDEO RELIABILITY FIX) */
add_filter( 'woocommerce_product_tabs', function( $tabs ) {
    global $post;
    $data = get_post_meta($post->ID, TABBY_KEY, true);
    if ( is_array($data) ) {
        foreach($data as $id => $tab) {
            $tabs['tabby_'.$id] = [
                'title'    => esc_html($tab['title'] ?: 'Resources'),
                'priority' => 50,
                'callback' => 'tabby_render_tab_content',
                'tab_data' => $tab
            ];
        }
    }
    return $tabs;
});

function tabby_render_tab_content($key, $tab_info) {
    $tab    = $tab_info['tab_data'];
    $layout = $tab['layout'] ?? 'editor';

    if ( $layout === 'video' && !empty($tab['videos']) ) {

        // Ensure wp-embed exists (some themes dequeue it)
        wp_enqueue_script('wp-embed');

        echo '<style>
            .tabby-video-wrapper { position: relative; z-index: 10; clear: both; }
            .tabby-v-container { position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:8px; background:#000; margin-bottom: 40px; }
            .tabby-v-container iframe { position:absolute; top:0; left:0; width:100%; height:100%; border:0; z-index: 5; pointer-events: auto !important; }
        </style>';

        /**
         * Key fix: If Divi/Woo hides tab panels with display:none at load,
         * YouTube iframes sometimes fail to initialize. We lazy-load by storing data-src,
         * then setting src only when the tab is activated.
         */
        echo '<script>
        (function(){
          function activateTabbyIframes(container){
            if(!container) return;
            var iframes = container.querySelectorAll("iframe[data-tabby-src]");
            iframes.forEach(function(iframe){
              if(!iframe.getAttribute("src")){
                iframe.setAttribute("src", iframe.getAttribute("data-tabby-src"));
              } else {
                // force refresh once on activation if needed
                var src = iframe.getAttribute("src");
                iframe.setAttribute("src", src);
              }
            });
          }

          function onReady(fn){
            if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", fn);
            else fn();
          }

          onReady(function(){
            // Initial attempt (in case tab is already visible)
            document.querySelectorAll(".tabby-video-wrapper").forEach(function(w){
              activateTabbyIframes(w);
            });

            // WooCommerce tab click handler: anchor href like #tab-tabby_row_0
            document.body.addEventListener("click", function(e){
              var a = e.target.closest && e.target.closest(".wc-tabs li a, .woocommerce-tabs ul.tabs li a");
              if(!a) return;

              // Wait for panel to become visible
              setTimeout(function(){
                // Active panel in WooCommerce has .woocommerce-Tabs-panel and is shown
                var panel = document.querySelector(".woocommerce-Tabs-panel:not([style*=display\\:none]) .tabby-video-wrapper")
                         || document.querySelector(".woocommerce-Tabs-panel .tabby-video-wrapper");
                if(panel) activateTabbyIframes(panel);
              }, 60);
            }, true);
          });
        })();
        </script>';

        echo '<div class="tabby-video-wrapper">';

        foreach($tab['videos'] as $vid) {
            $raw_url = trim((string)($vid['v_embed'] ?? ''));
            if ($raw_url === '') continue;

            $title = trim((string)($vid['v_title'] ?? ''));

            if ($title !== '') {
                echo '<h3>' . esc_html($title) . '</h3>';
            }

            // If user entered a plain URL, use oEmbed to generate correct markup.
            if ( filter_var($raw_url, FILTER_VALIDATE_URL) ) {
                // Prefer oEmbed HTML
                $embed_html = wp_oembed_get($raw_url);

                if ( $embed_html ) {
                    // Convert produced iframe to lazy-load: move src -> data-tabby-src, remove src
                    $embed_html = preg_replace_callback('/<iframe\b[^>]*>/i', function($m){
                        $tag = $m[0];
                        if ( preg_match('/\ssrc=("|\')([^"\']+)\\1/i', $tag, $sm) ) {
                            $src = $sm[2];
                            // remove src, add data-tabby-src and allow attrs if missing
                            $tag = preg_replace('/\ssrc=("|\')[^"\']+\\1/i', '', $tag);
                            if ( stripos($tag, 'data-tabby-src=') === false ) {
                                $tag = rtrim($tag, '>') . ' data-tabby-src="' . esc_attr($src) . '">';
                            }
                            if ( stripos($tag, 'allow=') === false ) {
                                $tag = rtrim($tag, '>') . ' allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share">';
                            }
                            if ( stripos($tag, 'allowfullscreen') === false ) {
                                $tag = rtrim($tag, '>') . ' allowfullscreen>';
                            }
                            if ( stripos($tag, 'loading=') === false ) {
                                $tag = rtrim($tag, '>') . ' loading="lazy">';
                            }
                        }
                        return $tag;
                    }, $embed_html );

                    echo '<div class="tabby-v-container">' . $embed_html . '</div>';
                    continue;
                }
            }

            // Fallback: treat as raw iframe/html but allow safe iframe attributes
            $allowed = [
                'iframe' => [
                    'src' => true,
                    'data-tabby-src' => true,
                    'width' => true,
                    'height' => true,
                    'frameborder' => true,
                    'allow' => true,
                    'allowfullscreen' => true,
                    'title' => true,
                    'loading' => true,
                    'referrerpolicy' => true,
                ],
                'p' => [],
                'br' => [],
                'div' => ['class' => true, 'style' => true],
            ];

            // If this is a raw YouTube embed src, convert to lazy data-tabby-src
            $html = $raw_url;
            if ( stripos($html, '<iframe') !== false ) {
                $html = preg_replace('/\ssrc=("|\')([^"\']+)\\1/i', ' data-tabby-src="$2"', $html);
                // Remove any leftover src attributes added by editors
                $html = preg_replace('/\ssrc=("|\')[^"\']+\\1/i', '', $html);
            }

            echo '<div class="tabby-v-container">' . wp_kses($html, $allowed) . '</div>';
        }

        echo '</div>';
        return;
    }

    // Render Text/Grid layouts... (Logic locked)
    echo apply_filters('the_content', $tab['content'] ?? '');
}

add_action( 'save_post_product', function( $post_id ) {
    if ( ! isset( $_POST['tabby_nonce_field'] ) || ! wp_verify_nonce( $_POST['tabby_nonce_field'], 'tabby_save_action' ) ) return;
    if ( isset($_POST['tabby_data']) ) update_post_meta($post_id, TABBY_KEY, $_POST['tabby_data']);
});
